{
  "name": "lodestone-cli",
  "version": "0.4.0",
  "description": "Stop paying Claude Code's cache tax: usage & cache monitoring, context handoffs, account switching. One command: lodestone.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "lodestone": "bin/lodestone.js"
  },
  "files": [
    "bin",
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pretest": "npm run build && tsc -p tsconfig.test.json && node -e \"fs.cpSync('test/fixtures','dist-test/test/fixtures',{recursive:true})\"",
    "test": "node scripts/test.mjs",
    "prepack": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "handoff",
    "context",
    "usage-limits",
    "prompt-cache",
    "multi-account",
    "account-switching",
    "statusline",
    "quota",
    "rate-limits",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VedantShirgaonkar/lodestone.git"
  },
  "bugs": {
    "url": "https://github.com/VedantShirgaonkar/lodestone/issues"
  },
  "homepage": "https://github.com/VedantShirgaonkar/lodestone",
  "author": "",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
