{
  "name": "warmswap",
  "version": "0.1.0",
  "description": "Switch Claude Code accounts without burning your usage limits: isolated per-account profiles + automated context handoffs, measured.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "warmswap": "bin/warmswap.js"
  },
  "files": [
    "bin",
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pretest": "npm run build && tsc -p tsconfig.test.json && node -e \"fs.cpSync('test/fixtures','dist-test/test/fixtures',{recursive:true})\"",
    "test": "node --test \"dist-test/test/*.test.js\"",
    "prepack": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "handoff",
    "context",
    "usage-limits",
    "prompt-cache",
    "multi-account",
    "account-switching",
    "statusline",
    "quota",
    "rate-limits",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/OWNER/warmswap"
  },
  "bugs": {
    "url": "https://github.com/OWNER/warmswap/issues"
  },
  "homepage": "https://github.com/OWNER/warmswap",
  "author": "",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
