{
  "name": "warmswap-vscode",
  "displayName": "warmswap",
  "description": "Claude Code account switching without the usage-limit tax — quota, cache countdowns, and one-click handoff.",
  "version": "0.1.0",
  "publisher": "OWNER-TODO",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/warmswap"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "warmswap.menu",
        "title": "warmswap: Menu"
      },
      {
        "command": "warmswap.handoffSwitch",
        "title": "warmswap: Handoff & Switch Account…"
      },
      {
        "command": "warmswap.keepWarm",
        "title": "warmswap: Keep Current Account Warm…"
      },
      {
        "command": "warmswap.openDash",
        "title": "warmswap: Open Dashboard (terminal)"
      },
      {
        "command": "warmswap.refresh",
        "title": "warmswap: Refresh Status"
      }
    ],
    "configuration": {
      "title": "warmswap",
      "properties": {
        "warmswap.expiryToastMinutes": {
          "type": "number",
          "default": 0,
          "description": "Show a toast notification when a project's cache is about to expire (within N minutes). 0 = disabled."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -p ./ -w",
    "pretest": "tsc -p ./tsconfig.test.json",
    "test": "node --test out-test/test/model.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.5.0"
  }
}
